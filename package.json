{
  "name": "teach",
  "productName": "Teach",
  "version": "0.1.0",
  "description": "Teach — every course is written on the fly",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@anthropic-ai/sdk": "^0.110.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
